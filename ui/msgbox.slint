import { VerticalBox, Button } from "std-widgets.slint";

export component MsgBoxWindow inherits Window {
	in property <string> message: "";
	in property <string> caption: "提示";

	title: caption;
	width: 360px;
	height: 200px;

	Rectangle {
		// provide a simple background panel for the message content
		border-width: 1px;
		border-color: #d0d0d0;
		background: #ffffff;
		x: 16px;
		y: 16px;
		width: parent.width - 32px;
		height: parent.height - 32px;

		VerticalBox {
			width: parent.width - 24px;
			height: parent.height - 32px;
			x: 12px;
			y: 12px;
			spacing: 12px;

			Text {
				width: parent.width;
				horizontal-stretch: 1;
				wrap: word-wrap;
				text: root.message;
				horizontal-alignment: left;
				vertical-alignment: top;
			}

			Button {
				text: "确定";
				horizontal-stretch: 0;
				clicked => {
					root.visible = false;
				}
			}
		}
	}
}
